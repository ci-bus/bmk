{
  "name": "BMK Firmware Dev",
  "dockerFile": "Dockerfile",
  "runArgs": ["--security-opt", "label=disable"],
  "containerEnv": {
    "WORKSPACE_DIR": "${containerWorkspaceFolder}"
  },
  "mounts": [
    "type=volume,source=bmk-root-user,target=/root",
    "type=volume,source=bmk-zephyr,target=${containerWorkspaceFolder}/zephyr",
    "type=volume,source=bmk-modules,target=${containerWorkspaceFolder}/modules",
    "type=volume,source=bmk-tools,target=${containerWorkspaceFolder}/tools",
    "type=volume,source=bmk-bootloader,target=${containerWorkspaceFolder}/bootloader"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "twxs.cmake",
        "marus25.cortex-debug",
        "trond-snekvik.kconfig-lang"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "forwardPorts": [3000]
}
